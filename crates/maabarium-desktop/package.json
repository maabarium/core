{
  "name": "maabarium-desktop",
  "version": "0.2.11",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc --noEmit && vite build",
    "build:release-manifest": "node ./scripts/generate-release-manifest.mjs",
    "publish:release-local": "bash ./scripts/run-local-desktop-release-r2.sh",
    "prepare:apple-certificate": "bash ./scripts/prepare-apple-certificate.sh",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "reset:macos-production-data": "bash ./scripts/reset-macos-production-data.sh",
    "test:release-local": "bash ./scripts/test-local-release-build.sh",
    "tauri": "tauri",
    "validate:updater-pubkey": "node ./scripts/validate-updater-pubkey.mjs"
  },
  "dependencies": {
    "@fontsource/azeret-mono": "^5.2.11",
    "@fontsource/m-plus-rounded-1c": "^5.2.10",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.2.0"
  }
}
